# ═══════════════════════════════════════════════════════════════════════════════
# .env.example
# Copy to .env and fill in real values. Never commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_strong_password
NEO4J_DATABASE=neo4j

# ─── Polymarket APIs (only needed for authenticated CLOB endpoints) ────────────
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ─── Copy Trading Bot ─────────────────────────────────────────────────────────
# Your wallet private key (0x...) — REQUIRED for copy-trading and btc-5m-bot
POLYMARKET_PRIVATE_KEY=
# Only for email/Magic wallets (your Polymarket profile address)
POLYMARKET_FUNDER_ADDRESS=

# ─── Config paths (optional — defaults shown) ─────────────────────────────────
POLYMARKET_CONFIG_PATH=config/polymarket.yaml
CRYPTO_CONFIG_PATH=config/crypto_data.yaml

# ─── Runtime ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
